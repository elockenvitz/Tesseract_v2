# Tesseract environment variables — copy this file to .env.local and
# fill in the values. .env.local is gitignored and stays on your machine.
#
# Production / staging values live in Netlify's Environment Variables
# dashboard, not here.

# ─── Supabase (required) ─────────────────────────────────────────────────
# Get these from Supabase dashboard → Settings → API.
# The anon key is safe to commit in client code (it's what your browser
# uses); the service_role key is NOT — it bypasses RLS and must never
# leave Bitwarden or .env.local.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ─── Financial data providers (optional) ─────────────────────────────────
# Used by src/lib/financial-data/ for prices, fundamentals, and history.
# The app falls back to free providers when these are absent — set them
# only if you want Alpha Vantage or Finnhub backing the data layer.
VITE_ALPHA_VANTAGE_API_KEY=
VITE_ALPHA_VANTAGE_PREMIUM=false
VITE_FINNHUB_API_KEY=

# ─── Financial data layer behavior (optional) ────────────────────────────
# Tuning knobs for the financial-data module. Sensible defaults are
# baked into the code; uncomment + set these only to override.
# VITE_FINANCIAL_DATA_PRIMARY_PROVIDER=alpha_vantage
# VITE_FINANCIAL_DATA_ENABLE_FALLBACK=true
# VITE_FINANCIAL_DATA_ENABLE_CACHING=true
# VITE_FINANCIAL_DATA_CACHE_TTL=900
